# ===== 키위보카 환경변수 템플릿 =====
# 실제 값은 .env 에 작성 (gitignored). 이 파일은 키 목록만 공유.

# --- 컨테이너/포트 ---
COMPOSE_CONTAINER_PREFIX=kiwivoca
HOST_PORT=8080
DB_HOST_PORT=5433

# --- PostgreSQL ---
POSTGRES_USER=kiwivoca
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=kiwivoca
# 백엔드가 사용하는 연결 문자열 (컨테이너 내부 호스트는 db)
DATABASE_URL=postgresql+psycopg2://kiwivoca:change_me_local@db:5432/kiwivoca

# --- 인증 (JWT) ---
SECRET_KEY=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Gemini (이미지→카드 추출) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- 발음 TTS: Google Cloud Text-to-Speech (Chirp 3 HD) ---
# GCP 프로젝트(Text-to-Speech API 활성화)의 API 키. REST text:synthesize 에 사용.
GOOGLE_TTS_API_KEY=
# Chirp 3 HD 별 이름(언어 공통). 후보: Achernar, Aoede, Kore, Charon, Puck 등
GOOGLE_TTS_VOICE=Achernar

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# --- OAuth: Kakao ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080/api/auth/kakao/callback

# --- CORS / 프론트 ---
CORS_ALLOWED_ORIGINS=http://localhost:8080
# OAuth 콜백 후 토큰을 fragment 로 넘겨줄 프론트 base URL
FRONTEND_BASE_URL=http://localhost:8080
# 프론트에서 사용하는 API base (nginx 프록시 기준)
VITE_API_BASE=/api
